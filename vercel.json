{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!api/|assets/|favicon\\.ico$|manifest(?:\\.json|\\.webmanifest)$|apple-touch-icon\\.png$|icon-192\\.png$|icon-512\\.png$|offline\\.html$|boot-sensor\\.js$|sw(?:-kill)?\\.js$).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/backup",
      "schedule": "59 23 * * *"
    }
  ]
}
