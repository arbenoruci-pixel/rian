{
  "name": "tepiha-vite-converted",
  "private": true,
  "version": "2.0.6-pwa-bootguard-v3",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "node server/index.mjs --dev",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.mjs",
    "cycles": "node tools/viteCircularDependencyPlugin.mjs",
    "cycles:strict": "CIRCULAR_FAIL=1 node tools/viteCircularDependencyPlugin.mjs --fail"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.48.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "multer": "^1.4.5-lts.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.1",
    "styled-jsx": "^5.1.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^1.2.0"
  }
}
