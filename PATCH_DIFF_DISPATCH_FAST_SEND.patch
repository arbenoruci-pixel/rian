+  let hardError = null;
+  settled.forEach((result) => {
+    if (result.status === 'rejected') {
+      hardError = hardError || result.reason;
+      return;
+    }
+    for (const row of result.value || []) {
+      const key = s(row?.id) || `${s(row?.code)}|${s(row?.code_str)}|${s(row?.code_n)}`;
